        monkeypatch.chdir(tmp_path)
        (tmp_path / "templates").mkdir()
        call_command("check_design_tokens")
        assert "No design token violations" in capsys.readouterr().out

    def test_detects_max_w_4xl(self, tmp_path, monkeypatch):
        monkeypatch.chdir(tmp_path)
        (tmp_path / "templates").mkdir()
        (tmp_path / "templates" / "bad.html").write_text('<div class="max-w-4xl">')
        with pytest.raises(CommandError, match="1 violation"):
            call_command("check_design_tokens")

    def test_detects_max_w_5xl(self, tmp_path, monkeypatch):
        monkeypatch.chdir(tmp_path)
        (tmp_path / "templates").mkdir()
        (tmp_path / "templates" / "bad.html").write_text('<div class="max-w-5xl">')
        with pytest.raises(CommandError, match="1 violation"):
            call_command("check_design_tokens")

    def test_detects_max_w_7xl(self, tmp_path, monkeypatch):
        monkeypatch.chdir(tmp_path)
        (tmp_path / "templates").mkdir()
        (tmp_path / "templates" / "bad.html").write_text('<div class="max-w-7xl">')
        with pytest.raises(CommandError, match="1 violation"):
            call_command("check_design_tokens")

    def test_counts_multiple_violations(self, tmp_path, monkeypatch):
        monkeypatch.chdir(tmp_path)
        (tmp_path / "templates").mkdir()
        for variant in ("max-w-4xl", "max-w-5xl", "max-w-7xl"):
            Path(tmp_path / "templates" / f"{variant}.html").write_text(
                f'<div class="{variant}">'
            )
        with pytest.raises(CommandError, match="3 violation"):
            call_command("check_design_tokens")

    def test_detects_violation_in_subdirectory(self, tmp_path, monkeypatch):
        monkeypatch.chdir(tmp_path)
        (tmp_path / "templates" / "projects").mkdir(parents=True)
        (tmp_path / "templates" / "projects" / "detail.html").write_text(
            '<div class="max-w-4xl">'
        )
        with pytest.raises(CommandError):
            call_command("check_design_tokens")

