# Enable Django debug mode
DEBUG=true
# Django secret key (change this in production)
SECRET_KEY=django-insecure-change-me-in-development
# PostgreSQL database URL
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres
# Redis URL
REDIS_URL=redis://127.0.0.1:6379/0
# Email server URL
EMAIL_URL=smtp://localhost:1025
# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1
# Serve via HTTPS
USE_HTTPS=false
# Trust X-Forwarded-Host header (set true behind a reverse proxy)
USE_X_FORWARDED_HOST=false
# Enable PostgreSQL connection pooling
USE_CONNECTION_POOL=false
# Run collectstatic on startup
USE_COLLECTSTATIC=false
# Django admin URL path
ADMIN_URL=admin/

# Enable browser auto-reload on code changes (development only)
USE_BROWSER_RELOAD=true
# Enable Django Debug Toolbar (development only)
USE_DEBUG_TOOLBAR=true
# Use watchfiles for reloading (development only)
USE_WATCHFILES=true

# ── Deployment ────────────────────────────────────────────────────────────────
# Add these before running /dj-launch. Values are read from the environment
# (.env is gitignored — safe to add real values here. Do not add real values to .env.example).
#
# Required
# Hetzner Cloud API token (Read & Write)
# HETZNER_TOKEN=
# Cloudflare API token (Zone permissions)
# CLOUDFLARE_TOKEN=
#
# Required for email
# Mailgun sending API key
# MAILGUN_API_KEY=
#
# Optional
# Mailgun DKIM TXT record value (for DNS setup)
# MAILGUN_DKIM_VALUE=
# Hetzner object storage access key
# HETZNER_STORAGE_ACCESS_KEY=
# Hetzner object storage secret key
# HETZNER_STORAGE_SECRET_KEY=
# Sentry DSN URL
# SENTRY_DSN=
# OpenTelemetry collector endpoint URL
# OTLP_ENDPOINT=
# Grafana admin password (auto-generated if unset)
# GRAFANA_ADMIN_PASSWORD=
