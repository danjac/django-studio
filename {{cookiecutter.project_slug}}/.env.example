DEBUG=true
SECRET_KEY=django-insecure-change-me-in-development
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres
REDIS_URL=redis://127.0.0.1:6379/0
EMAIL_URL=smtp://localhost:1025
ALLOWED_HOSTS=localhost,127.0.0.1
USE_HTTPS=false
USE_X_FORWARDED_HOST=false
USE_CONNECTION_POOL=false
USE_COLLECTSTATIC=false
ADMIN_URL=admin/

# Optional: Mailgun (replaces SMTP)
# MAILGUN_API_KEY=
# MAILGUN_SENDER_DOMAIN=
# MAILGUN_API_URL=https://api.mailgun.net/v3

# Optional: Sentry
# SENTRY_URL=

# Optional: OpenTelemetry
# OPEN_TELEMETRY_URL=
# OPEN_TELEMETRY_SERVICE_NAME={{cookiecutter.project_slug}}

# Optional: dev tools
# USE_BROWSER_RELOAD=true
# USE_DEBUG_TOOLBAR=true
# USE_WATCHFILES=true
